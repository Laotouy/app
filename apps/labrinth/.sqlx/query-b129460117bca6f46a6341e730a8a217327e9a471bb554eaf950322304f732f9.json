  "query": "\n                SELECT a.applicant_user_id, a.project_id, m.name AS \"project_name?\"\n                FROM incentive_applications a\n                LEFT JOIN mods m ON m.id = a.project_id\n                WHERE a.thread_id = $1\n                ORDER BY a.created_at DESC LIMIT 1\n                ",
