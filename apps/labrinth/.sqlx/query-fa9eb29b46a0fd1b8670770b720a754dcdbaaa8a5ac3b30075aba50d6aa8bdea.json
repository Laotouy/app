  "query": "\n        SELECT p.id, p.user_id, p.amount, p.fee, p.status, p.method, p.method_address,\n               p.platform_id, p.yunzhanghu_submit_started_at,\n               p.yunzhanghu_submit_finished_at, u.username\n        FROM payouts p\n        INNER JOIN users u ON u.id = p.user_id\n        WHERE p.id = $1\n        FOR UPDATE OF p\n        ",
